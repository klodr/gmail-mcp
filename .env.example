# Gmail OAuth keys. Path to the gcp-oauth.keys.json file downloaded from
# Google Cloud Console (APIs & Services → Credentials → OAuth 2.0 client
# IDs → Desktop app type → Download JSON). Defaults to ~/.gmail-mcp/
# gcp-oauth.keys.json if unset.
# GMAIL_OAUTH_PATH=/abs/path/gcp-oauth.keys.json

# Where the runtime tokens (refresh + access + scope list) are persisted
# after the one-shot `npx @klodr/gmail-mcp auth` flow. Mode 0o600. Default
# is ~/.gmail-mcp/credentials.json.
# GMAIL_CREDENTIALS_PATH=/abs/path/credentials.json

# --- Safeguards (all optional) ---

# Append-only redacted JSONL audit log of every tool call. Sender + Gmail
# IDs + scopes + result are kept; subject / body / attachments are
# elided by default. Must be an absolute path; mode 0o600 enforced.
# GMAIL_MCP_AUDIT_LOG=/abs/path/audit.jsonl

# Verbose audit: include subject + body excerpts (counterparty PII).
# OFF by default. Only enable for debugging on a private machine — the
# audit log will then contain inbox content.
# GMAIL_MCP_AUDIT_LOG_VERBOSE=true

# --- Recipient-pairing gate (opt-in) ---

# When set to true, every send_email / reply_all / draft_email recipient
# (To/Cc/Bcc) must appear in ~/.gmail-mcp/paired.json (managed via the
# pair_recipient tool). Caps the blast radius of a prompt-injection-driven
# send. OFF by default — legacy users see no change.
# GMAIL_MCP_RECIPIENT_PAIRING=true

# Override paired.json location (defaults to ~/.gmail-mcp/paired.json,
# mode 0o600).
# GMAIL_MCP_PAIRED_PATH=/abs/path/paired.json
