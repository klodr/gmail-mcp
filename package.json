{
  "name": "@klodr/gmail-mcp",
  "version": "0.1.0",
  "description": "Gmail MCP server — scope-gated tools + attachment/download path jails + supply-chain hardening. Fork of GongRzhe/Gmail-MCP-Server via ArtyMcLabin's intermediate fork.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gmail-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "auth": "node dist/index.js auth",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gmail",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai",
    "llm",
    "agent-tools",
    "oauth",
    "google-gmail",
    "claude",
    "cursor",
    "typescript",
    "nodejs"
  ],
  "author": "klodr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klodr/gmail-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/klodr/gmail-mcp/issues"
  },
  "homepage": "https://github.com/klodr/gmail-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "email-addresses": "^5.0.0",
    "google-auth-library": "^9.4.1",
    "googleapis": "^129.0.0",
    "mime-types": "^3.0.1",
    "nodemailer": "^7.0.11",
    "open": "^10.0.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "mcp-evals": "^1.0.18",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.18"
  }
}
